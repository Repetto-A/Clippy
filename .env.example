# Copiá a .env y ajustá. Todas son opcionales (hay defaults).

# Carpeta de trabajo donde se guardan artefactos y clips
VC_WORKDIR=work

# --- Transcripción (requiere extra 'asr') ---
VC_WHISPER_MODEL=large-v3
VC_WHISPER_DEVICE=cuda
VC_WHISPER_COMPUTE=float16
VC_WHISPER_CHUNK_SECONDS=600
VC_LANGUAGE=es

# --- Scoring de momentos ---
# VC_SCORER: "heuristic" (sin LLM, baseline) | "llm" (usa el proveedor de abajo)
VC_SCORER=llm
# VC_LLM_PROVIDER:
#   "ollama"   -> local en tu GPU (gratis, privado)
#   "opencode" -> usa tu suscripción vía el CLI `opencode run` (sin API key propia)
#   "anthropic"-> API de Anthropic (requiere ANTHROPIC_API_KEY)
VC_LLM_PROVIDER=opencode
# Modelo segun proveedor:
#   ollama    -> p.ej. "qwen2.5:7b-instruct"
#   opencode  -> "provider/model", p.ej. "opencode-go/deepseek-v4-flash" (rapido) o "opencode-go/deepseek-v4-pro" (mejor calidad)
#   anthropic -> "claude-sonnet-4-20250514"
VC_LLM_MODEL=opencode-go/deepseek-v4-flash
VC_OLLAMA_HOST=http://localhost:11434
# Timeout (s) para cada llamada del backend opencode
VC_OPENCODE_TIMEOUT=600
ANTHROPIC_API_KEY=

# --- Selección de clips ---
VC_MIN_DURATION=15
VC_MAX_DURATION=60
VC_TARGET_CLIPS=12
# Candidatos que pasan a la pasada rank (M2)
VC_RANK_FINALISTS=24

# Chunking LLM para videos largos (transcripts > ~12k chars)
VC_LLM_CHUNK_CHARS=12000
VC_LLM_CLIPS_PER_CHUNK=6

# --- Salidas ---
VC_OUT_VERTICAL=1
VC_OUT_HORIZONTAL=1
VC_TRANSLATE_EN=0

# --- Render ---
VC_NVENC=1
VC_WEBCAM_DETECT_SAMPLES=5

# Overlap entre chunks LLM (segmentos repetidos en la frontera)
VC_CHUNK_OVERLAP=1

# Subtitulos: karaoke | social | both
VC_CAPTION_STYLE=karaoke
VC_CAPTION_SOCIAL_WORDS=5
